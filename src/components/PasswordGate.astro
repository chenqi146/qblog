---
import { createHash } from "node:crypto";

interface Props {
	redirectTo?: string;
}

const { redirectTo } = Astro.props;
const configuredPassword = import.meta.env.SITE_PASSWORD?.trim() || "please-change-me";
const usingDefaultPassword = !import.meta.env.SITE_PASSWORD?.trim();
const passwordHash = createHash("sha256").update(configuredPassword).digest("hex");
const storageKey = "qblog.site-password.v1";
const redirectTarget = redirectTo ?? "";
---

<script
	is:inline
	define:vars={{
		passwordHash,
		storageKey,
	}}
>
	(() => {
		const root = document.documentElement;
		try {
			const stored = window.localStorage.getItem(storageKey);
			root.dataset.siteGate = stored === passwordHash ? "granted" : "locked";
		} catch {
			root.dataset.siteGate = "locked";
		}
	})();
</script>

<style is:inline>
	html[data-site-gate="locked"] {
		overflow: hidden;
	}

	html[data-site-gate="locked"] .site-shell,
	html[data-site-gate="locked"] .site-background {
		visibility: hidden;
		pointer-events: none;
		user-select: none;
	}

	html[data-site-gate="granted"] .site-password-gate {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.site-password-gate {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: grid;
		place-items: center;
		padding: 2rem;
		background:
			radial-gradient(circle at 20% 20%, rgba(163, 255, 164, 0.09), transparent 28%),
			radial-gradient(circle at 80% 30%, rgba(102, 204, 255, 0.12), transparent 26%),
			linear-gradient(180deg, rgba(5, 10, 9, 0.94), rgba(3, 6, 6, 0.98));
		backdrop-filter: blur(18px);
		transition:
			opacity 0.2s ease,
			visibility 0.2s ease;
	}

	.site-password-panel {
		width: min(100%, 30rem);
		padding: 1.5rem;
		border: 1px solid rgba(110, 199, 167, 0.3);
		background:
			linear-gradient(180deg, rgba(11, 20, 18, 0.96), rgba(7, 12, 11, 0.98));
		box-shadow:
			0 24px 80px rgba(0, 0, 0, 0.42),
			inset 0 0 0 1px rgba(255, 255, 255, 0.03);
		color: #edf7f1;
	}

	.site-password-eyebrow {
		margin: 0 0 0.75rem;
		color: #9df8c9;
		font-size: 0.8rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
	}

	.site-password-title {
		margin: 0;
		font-size: clamp(1.75rem, 5vw, 2.25rem);
		line-height: 1.05;
	}

	.site-password-copy,
	.site-password-hint,
	.site-password-warning,
	.site-password-error {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.site-password-copy,
	.site-password-hint {
		color: rgba(237, 247, 241, 0.72);
	}

	.site-password-warning {
		display: none;
		padding: 0.75rem 0.875rem;
		border: 1px solid rgba(255, 197, 102, 0.3);
		background: rgba(255, 197, 102, 0.08);
		color: #ffd693;
	}

	.site-password-warning.is-visible {
		display: block;
	}

	.site-password-form {
		display: grid;
		gap: 0.75rem;
		margin: 1.5rem 0 0.875rem;
	}

	.site-password-label {
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: #9df8c9;
	}

	.site-password-input {
		width: 100%;
		padding: 0.95rem 1rem;
		border: 1px solid rgba(117, 163, 144, 0.35);
		border-radius: 0;
		background: rgba(3, 6, 6, 0.82);
		color: #f5fff9;
		font: inherit;
	}

	.site-password-input:focus {
		outline: 1px solid #9df8c9;
		outline-offset: 2px;
		border-color: #9df8c9;
	}

	.site-password-submit {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.95rem 1rem;
		border: 1px solid #9df8c9;
		border-radius: 0;
		background: linear-gradient(90deg, #bfff77, #8df6be);
		color: #07100f;
		font: inherit;
		font-weight: 700;
		cursor: pointer;
		transition:
			transform 0.15s ease,
			filter 0.15s ease;
	}

	.site-password-submit:hover,
	.site-password-submit:focus-visible {
		transform: translateY(-1px);
		filter: brightness(1.04);
		outline: none;
	}

	.site-password-meta {
		display: grid;
		gap: 0.75rem;
		padding-top: 1rem;
		border-top: 1px solid rgba(117, 163, 144, 0.18);
	}

	.site-password-error {
		color: #ffb8a1;
	}

	.site-password-error[hidden] {
		display: none;
	}

	.site-password-noscript {
		margin-top: 0.75rem;
		color: #ffd693;
		font-size: 0.9rem;
	}

	@media (max-width: 640px) {
		.site-password-gate {
			padding: 1rem;
		}

		.site-password-panel {
			padding: 1.25rem;
		}
	}
</style>

<div class="site-password-gate" role="dialog" aria-modal="true" aria-labelledby="site-password-title">
	<div class="site-password-panel">
		<p class="site-password-eyebrow">Private Access</p>
		<h1 class="site-password-title" id="site-password-title">输入站点密码</h1>
		<p class="site-password-copy">这个博客已启用固定密码访问。验证成功后会在当前浏览器记住访问状态。</p>
		<p class:list={["site-password-warning", usingDefaultPassword && "is-visible"]}>
			当前还在使用默认密码 `please-change-me`，上线前请改掉。
		</p>

		<form class="site-password-form" data-password-form>
			<label class="site-password-label" for="site-password-input">Passphrase</label>
			<input
				class="site-password-input"
				id="site-password-input"
				name="password"
				type="password"
				autocomplete="current-password"
				spellcheck="false"
				required
				data-password-input
			/>
			<button class="site-password-submit" type="submit">进入站点</button>
		</form>

		<div class="site-password-meta">
			<p class="site-password-hint">
				{redirectTarget ? "验证成功后会继续跳转到目标页面。" : "如果你修改了密码，旧的浏览器访问记录会自动失效。"}
			</p>
			<p class="site-password-error" data-password-error hidden>密码不正确，请重试。</p>
			<noscript>
				<p class="site-password-noscript">这个站点的密码门禁需要启用 JavaScript。</p>
			</noscript>
		</div>
	</div>
</div>

<script
	is:inline
	define:vars={{
		passwordHash,
		redirectTarget,
		storageKey,
	}}
>
	(() => {
		const root = document.documentElement;
		const gate = document.querySelector(".site-password-gate");
		const form = gate?.querySelector("[data-password-form]");
		const input = gate?.querySelector("[data-password-input]");
		const error = gate?.querySelector("[data-password-error]");

		const focusInput = () => {
			if (root.dataset.siteGate === "locked") {
				window.requestAnimationFrame(() => input?.focus());
			}
		};

		const grantAccess = () => {
			root.dataset.siteGate = "granted";
			error?.setAttribute("hidden", "");
			if (input instanceof HTMLInputElement) {
				input.value = "";
			}

			if (redirectTarget) {
				window.location.replace(redirectTarget);
			}
		};

		const sha256 = async (value) => {
			const bytes = new TextEncoder().encode(value);
			const digest = await window.crypto.subtle.digest("SHA-256", bytes);
			return Array.from(new Uint8Array(digest), (byte) => byte.toString(16).padStart(2, "0")).join("");
		};

		if (root.dataset.siteGate === "granted") {
			if (redirectTarget) {
				window.location.replace(redirectTarget);
			}
			return;
		}

		focusInput();

		form?.addEventListener("submit", async (event) => {
			event.preventDefault();

			if (!(input instanceof HTMLInputElement)) {
				return;
			}

			const candidate = input.value.trim();
			if (!candidate) {
				error?.removeAttribute("hidden");
				return;
			}

			const candidateHash = await sha256(candidate);
			if (candidateHash !== passwordHash) {
				error?.removeAttribute("hidden");
				input.select();
				return;
			}

			try {
				window.localStorage.setItem(storageKey, passwordHash);
			} catch {
				// Ignore storage failures and still unlock the page for the current session.
			}

			grantAccess();
		});
	})();
</script>
