---
import type { ImageMetadata } from "astro";
import ImageGlow from "./ImageGlow.astro";
import type { ImageCredit } from "../lib/image-credit";

interface Props {
	href: string;
	title: string;
	description: string;
	date: Date;
	image: ImageMetadata;
	imageAlt?: string;
	imageCredit?: ImageCredit;
	dataTags?: string;
}

const {
	href,
	title,
	description,
	date,
	image,
	imageAlt = title,
	dataTags,
} = Astro.props;
---

<a href={href} class="post-container" data-tags={dataTags}>
	<div class="post-copy">
		<div class="post-header">
			<h3>{title}</h3>
			<time class="post-date" datetime={date.toISOString()}>
				{date.toLocaleDateString()}
			</time>
		</div>
		<p class="post-description">{description}</p>
	</div>
	<div class="post-media">
		<ImageGlow
			src={image}
			alt={imageAlt}
			width={960}
			height={540}
			quality={95}
			loading="lazy"
			class="post-thumbnail"
		/>
	</div>
</a>

<style>
	.post-container {
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border: 1px solid #2b3533;
		background:
			linear-gradient(180deg, rgba(12, 18, 17, 0.94), rgba(8, 12, 12, 0.98));
		color: #ffffff;
		text-decoration: none;
		box-shadow:
			0 16px 42px rgba(0, 0, 0, 0.18),
			inset 0 0 0 1px rgba(255, 255, 255, 0.02);
		transition:
			background-color 0.15s ease,
			border 0.15s ease,
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.post-container:hover,
	.post-container:focus-visible {
		border: 1px solid var(--primary);
		transform: translateY(-2px);
		box-shadow:
			0 22px 54px rgba(0, 0, 0, 0.24),
			0 0 0 1px rgba(140, 92, 245, 0.14);
	}

	.post-container:focus-visible {
		outline: none;
	}

	.post-media {
		min-width: 0;
		padding: 0 1rem 1rem;
	}

	.post-thumbnail {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
		border-radius: 1rem;
		border: 1px solid rgba(157, 248, 201, 0.08);
		background: #0c1218;
	}

	.post-copy {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		min-width: 0;
		padding: 1rem 1rem 0.85rem;
	}

	.post-header {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		align-items: flex-start;
	}

	.post-header h3 {
		margin: 0;
		font-size: 1.08rem;
		line-height: 1.3;
	}

	.post-description {
		margin: 0;
		line-height: 1.55;
		color: #d6d6d6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-date {
		color: #a8b4af;
		font-family: "Geist Mono", "Courier New", Courier, monospace;
		font-size: 0.82rem;
		letter-spacing: 0.04em;
	}

	@media screen and (max-width: 640px) {
		.post-thumbnail {
			aspect-ratio: 16 / 10;
		}

		.post-copy {
			padding: 0.9rem 0.9rem 0.75rem;
		}

		.post-media {
			padding: 0 0.9rem 0.9rem;
		}
	}
</style>
