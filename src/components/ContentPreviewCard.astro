---
import type { ImageMetadata } from "astro";
import ImageGlow from "./ImageGlow.astro";

interface Props {
	href: string;
	title: string;
	description: string;
	date: Date;
	image: ImageMetadata;
	imageAlt?: string;
	dataTags?: string;
}

const {
	href,
	title,
	description,
	date,
	image,
	imageAlt = title,
	dataTags,
} = Astro.props;
---

<a href={href} class="post-container" data-tags={dataTags}>
	<div class="post-media">
		<ImageGlow
			src={image}
			alt={imageAlt}
			width={208}
			height={132}
			quality={95}
			loading="lazy"
			class="post-thumbnail"
		/>
	</div>
	<div class="post-copy">
		<div class="post-header">
			<h3>{title}</h3>
			<span class="post-date">{date.toLocaleDateString()}</span>
		</div>
		<p class="post-description">{description}</p>
	</div>
</a>

<style>
	.post-container {
		display: grid;
		grid-template-columns: 208px minmax(0, 1fr);
		gap: 1rem;
		align-items: stretch;
		padding: 1rem;
		border: 1px solid #353535;
		color: #ffffff;
		text-decoration: none;
		transition:
			background-color 0.15s ease,
			border 0.15s ease,
			transform 0.15s ease;
	}

	.post-container:hover,
	.post-container:focus-visible {
		background-color: rgba(140, 92, 245, 0.125);
		border: 1px solid var(--primary);
		transform: translateY(-1px);
	}

	.post-container:focus-visible {
		outline: none;
	}

	.post-media {
		min-width: 0;
	}

	.post-thumbnail {
		width: 100%;
		height: 100%;
		min-height: 132px;
		border: 1px solid #2d3b38;
		object-fit: cover;
		background: #0c1218;
	}

	.post-copy {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		min-width: 0;
	}

	.post-header {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: space-between;
		align-items: baseline;
	}

	.post-header h3 {
		margin: 0;
	}

	.post-description {
		margin: 0;
		line-height: 1.55;
		color: #d6d6d6;
	}

	.post-date {
		color: #c7c7c7;
		flex-shrink: 0;
	}

	@media screen and (max-width: 720px) {
		.post-container {
			grid-template-columns: 1fr;
		}

		.post-thumbnail {
			min-height: 176px;
		}
	}
</style>
