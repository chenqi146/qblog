---
import "../styles/reset.css";
import "../styles/globals.css";

import { name, themeColor, twitterHandle } from "spectre:globals";
import Background from "../components/Background.astro";
import LayoutGrid from "../components/LayoutGrid.astro";
import Navbar from "../components/Navbar.astro";
import PasswordGate from "../components/PasswordGate.astro";
import { withBase } from "../lib/base";

interface Props {
	title: string;
	description?: string;
	image?: ImageMetadata;
	pagefindIgnore?: boolean;
	article?: {
		createdAt: Date;
		updatedAt?: Date;
	};
}

const { title, description, image, pagefindIgnore, article } = Astro.props;
const defaultOgImage = new URL(withBase("img/og.png"), Astro.site).toString();
const ogImage = image?.src
	? new URL(image.src, Astro.site).toString()
	: defaultOgImage;
---

<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
	<head>
		<script is:inline>
			try {
				const storedTheme = window.localStorage.getItem("qblog-theme");
				if (storedTheme === "light" || storedTheme === "dark") {
					document.documentElement.dataset.theme = storedTheme;
				}
			} catch {
				document.documentElement.dataset.theme = "dark";
			}
		</script>
		<link
			rel="preload"
			href={withBase("fonts/Geist.woff2")}
			as="font"
			type="font/woff2"
			crossorigin=""
		/>
		<link
			rel="preload"
			href={withBase("fonts/GeistMono.woff2")}
			as="font"
			type="font/woff2"
			crossorigin=""
		/>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		<meta name="theme-color" content={themeColor} />

		<link rel="canonical" href={Astro.url} />

		<meta name="og:title" content={title} />
		{description && <meta name="og:description" content={description} />}
		<meta name="og:image" content={ogImage} />
		<meta name="og:url" content={Astro.url.toString()} />
		{!article && <meta name="og:type" content="website" />}
		<meta name="og:locale" content="zh_CN" />

		{article && (
			<meta name="og:type" content="article" />
			<meta property="article:published_time" content={article.createdAt.toISOString()} />
			<meta name="author" content={name} />
		)}

		{article && article.updatedAt && (
			<meta property="article:modified_time" content={article.updatedAt.toISOString()} />
		)}

		<meta name="twitter:card" content="summary_large_image" />
		{twitterHandle && (
			<meta name="twitter:site" content={twitterHandle} />
			<meta name="twitter:creator" content={twitterHandle} />
		)}
		<meta name="twitter:title" content={title} />
		{description && <meta name="twitter:description" content={description} />}
		<meta name="twitter:image" content={ogImage} />
	</head>
	<body>
		<PasswordGate />
		<main class="site-shell" data-pagefind-ignore={pagefindIgnore}>
			<Navbar />
			<LayoutGrid>
				<slot name="left" slot="left" />
				<slot name="right" slot="right" />
			</LayoutGrid>
			<slot name="404" />
		</main>
		<div class="site-background">
			<Background />
		</div>
	</body>
</html>
